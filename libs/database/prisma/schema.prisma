// Bellat Platform — Prisma Schema
// Reference: docs/schema-prototype.sql
// Target: Supabase (PostgreSQL 15)
//   - DATABASE_URL : pooled connection via pgBouncer (port 6543) — used at runtime
//   - DIRECT_URL   : direct connection (port 5432) — used by prisma migrate only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum UserRole {
  customer
  admin
}

enum StockStatus {
  in_stock
  low_stock
  out_of_stock
}

enum OrderStatus {
  pending
  confirmed
  preparing
  out_for_delivery
  delivered
  cancelled
}

// ─────────────────────────────────────────────
// Category
// ─────────────────────────────────────────────

model Category {
  // Slug-style id, e.g. "kachir", "rotis"
  id        String    @id @db.VarChar(50)
  nameFr    String    @db.VarChar(100)
  nameAr    String    @db.VarChar(100)
  icon      String?   @db.VarChar(10)
  imageUrl  String?   @db.VarChar(255)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  products  Product[]

  @@map("categories")
}

// ─────────────────────────────────────────────
// Product
// ─────────────────────────────────────────────

model Product {
  // Slug-style id, e.g. "prod_001"
  id            String      @id @db.VarChar(50)
  nameFr        String      @db.VarChar(255)
  nameAr        String      @db.VarChar(255)
  descriptionFr String?
  descriptionAr String?
  categoryId    String?     @db.VarChar(50)
  imageUrl      String?     @db.VarChar(255)
  // Price in DZD — no decimal places used in practice, Decimal preserves exact values
  price         Decimal     @db.Decimal(10, 2)
  unit          String?     @db.VarChar(50)
  stockStatus   StockStatus @default(in_stock)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems    OrderItem[]
  favorites     Favorite[]

  @@index([categoryId])
  @@map("products")
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  fullName     String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  // Algerian phone format: +213XXXXXXXXX
  phoneNumber  String?   @unique @db.VarChar(20)
  passwordHash String    @db.VarChar(255)
  role         UserRole  @default(customer)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  addresses    Address[]
  orders       Order[]
  favorites    Favorite[]

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────────
// Address
// ─────────────────────────────────────────────

model Address {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  fullName     String   @db.VarChar(100)
  phoneNumber  String   @db.VarChar(20)
  addressLine1 String   @db.VarChar(255)
  addressLine2 String?  @db.VarChar(255)
  // One of 48 Algerian wilayas (administrative divisions, codes 1–48)
  wilaya       String   @db.VarChar(100)
  commune      String   @db.VarChar(100)
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("addresses")
}

// ─────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────

model Order {
  // Human-readable id generated by the app, e.g. "BLT-20260104-00001"
  id              String      @id @db.VarChar(50)
  customerId      String      @db.Uuid
  status          OrderStatus @default(pending)

  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)

  // Snapshot of delivery address at time of order (JSONB)
  // Stored inline rather than linked to addresses table so it survives address deletion
  deliveryAddress Json
  deliverySlotDate DateTime   @db.Date
  // e.g. "Matin (8h - 12h)" or "Après-midi (14h - 18h)"
  deliverySlotTime String     @db.VarChar(100)

  // Primary payment method in Algeria is cash on delivery
  paymentMethod   String      @default("cash_on_delivery") @db.VarChar(50)

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  customer        User        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items           OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

// ─────────────────────────────────────────────
// Favorite
// ─────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  productId String   @db.VarChar(50)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("favorites")
}

// ─────────────────────────────────────────────
// Setting
// Key-value store for admin-configurable platform settings
// ─────────────────────────────────────────────

model Setting {
  // Dot-namespaced key, e.g. "app.contact_email", "features.welcome_email"
  key         String   @id @db.VarChar(100)
  value       String   @db.Text
  // Human-readable label shown in the admin settings UI
  label       String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────
// OrderItem
// ─────────────────────────────────────────────

model OrderItem {
  id              String  @id @default(uuid()) @db.Uuid
  orderId         String  @db.VarChar(50)
  productId       String  @db.VarChar(50)
  quantity        Int
  // Price captured at time of purchase — insulates against future price changes
  priceAtPurchase Decimal @db.Decimal(10, 2)

  order           Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product         Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([orderId, productId])
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}
