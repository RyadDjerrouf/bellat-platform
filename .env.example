# Bellat Platform - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/bellat"
DATABASE_URL_UNPOOLED="postgresql://postgres:password@localhost:5432/bellat"

# ==========================================
# Redis Configuration
# ==========================================
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# ==========================================
# JWT Secrets
# ==========================================
# Generate secure secrets: openssl rand -base64 64
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_REFRESH_SECRET="your-refresh-secret-key-here"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="30d"

# ==========================================
# OAuth Configuration
# ==========================================
# Google OAuth
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"

# Facebook OAuth
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"

# ==========================================
# API Configuration
# ==========================================
API_URL="http://localhost:3000/api/v1"
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ==========================================
# Firebase Cloud Messaging (FCM)
# ==========================================
FCM_PROJECT_ID="your-firebase-project-id"
FCM_PRIVATE_KEY="your-firebase-private-key"
FCM_CLIENT_EMAIL="your-firebase-client-email"
NEXT_PUBLIC_FCM_VAPID_KEY="your-fcm-vapid-key"

# ==========================================
# Email Service (SendGrid)
# ==========================================
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@bellat.net"
SENDGRID_FROM_NAME="Bellat"

# ==========================================
# SMS Gateway (Algerian Provider)
# ==========================================
SMS_GATEWAY_API_KEY="your-algerian-sms-api-key"
SMS_GATEWAY_URL="https://api.sms-provider.dz"
SMS_GATEWAY_SENDER_ID="Bellat"

# ==========================================
# Application Settings
# ==========================================
NODE_ENV="development"
PORT="3000"
ADMIN_PORT="3001"
API_GATEWAY_PORT="3002"

# ==========================================
# Frontend Configuration
# ==========================================
NEXT_PUBLIC_APP_NAME="Bellat"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LANGUAGE="fr"
NEXT_PUBLIC_SUPPORTED_LANGUAGES="ar,fr"

# ==========================================
# File Storage (S3-compatible)
# ==========================================
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="bellat-products"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
S3_REGION="us-east-1"

# ==========================================
# Monitoring & Logging
# ==========================================
SENTRY_DSN=""
LOG_LEVEL="debug"

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_PUBLIC="100"
RATE_LIMIT_AUTHENTICATED="1000"

# ==========================================
# Session Configuration
# ==========================================
SESSION_SECRET="your-session-secret-here"
SESSION_MAX_AGE="86400"  # 24 hours in seconds

# ==========================================
# Algerian Settings
# ==========================================
DEFAULT_CURRENCY="DZD"
DEFAULT_TIMEZONE="Africa/Algiers"
MIN_ORDER_AMOUNT="1500"  # Default minimum order in DZD

# ==========================================
# Feature Flags
# ==========================================
FEATURE_SOCIAL_LOGIN="true"
FEATURE_PUSH_NOTIFICATIONS="true"
FEATURE_OFFLINE_MODE="true"
